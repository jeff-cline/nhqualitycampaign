generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  EDITOR
}

enum PageStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum PageType {
  ARTICLE
  GUIDE
  COMPARISON
  FAQ
  HUB
  STATE
  LEGAL
  BLOG
}

enum Cluster {
  A_MEDICARE
  B_NURSING_HOMES
  C_SENIOR_CARE
  D_TELEHEALTH
  E_HEALTHCARE_QUALITY
  F_SENIOR_FINANCE
  NONE
}

enum AdPosition {
  HEADER_BANNER
  SIDEBAR_TOP
  SIDEBAR_MID
  SIDEBAR_STICKY
  IN_CONTENT_1
  IN_CONTENT_2
  BEFORE_FAQ
  AFTER_ARTICLE
  FOOTER_BANNER
  MOBILE_STICKY
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  role          Role     @default(EDITOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pages         Page[]
}

model Page {
  id            String     @id @default(cuid())
  slug          String     @unique
  path          String     @unique
  title         String
  h1            String?
  metaTitle     String?
  metaDesc      String?
  quickAnswer   String?
  content       String     @default("")
  excerpt       String?
  pageType      PageType   @default(ARTICLE)
  cluster       Cluster    @default(NONE)
  status        PageStatus @default(DRAFT)
  schemaType    String?
  canonicalUrl  String?
  ogImage       String?
  authorId      String?
  author        User?      @relation(fields: [authorId], references: [id])
  faq           Faq[]
  adOverrides   PageAdSlot[]
  publishedAt   DateTime?
  scheduledAt   DateTime?
  updatedAt     DateTime   @updatedAt
  createdAt     DateTime   @default(now())

  @@index([status, cluster])
  @@index([pageType])
}

model Faq {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  sortOrder Int      @default(0)
}

model AdSlot {
  id          String      @id @default(cuid())
  slotKey     String      @unique
  name        String
  position    AdPosition
  code        String      @default("")
  isActive    Boolean     @default(false)
  sitewide    Boolean     @default(true)
  notes       String?
  overrides   PageAdSlot[]
  updatedAt   DateTime    @updatedAt
  createdAt   DateTime    @default(now())
}

model PageAdSlot {
  id        String   @id @default(cuid())
  pageId    String
  adSlotId  String
  enabled   Boolean  @default(true)
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  adSlot    AdSlot   @relation(fields: [adSlotId], references: [id], onDelete: Cascade)

  @@unique([pageId, adSlotId])
}

model ContentBlock {
  id         String   @id @default(cuid())
  key        String   @unique
  kind       String
  data       Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model Analytics {
  id        String   @id @default(cuid())
  path      String
  source    String?
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([path, createdAt])
}

model Setting {
  key   String @id
  value String
}
