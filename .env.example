# --- Database (Supabase PostgreSQL via Supavisor) ---
# DATABASE_URL: Transaction pooler (port 6543) — use for app runtime / serverless
# DIRECT_URL:   Session pooler (port 5432) — use for migrations and seeding
# Both use the same host; different ports and params.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# --- NextAuth ---
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://nhqualitycampaign.org"

# --- DataForSEO ---
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# --- Google Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://nhqualitycampaign.org"

# --- Admin seed ---
SEED_ADMIN_EMAIL="admin@nhqualitycampaign.org"
SEED_ADMIN_PASSWORD=""

# --- Optional ---
ANTHROPIC_API_KEY=""
